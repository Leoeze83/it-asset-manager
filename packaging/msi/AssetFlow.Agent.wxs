<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="AssetFlow Agent Installer"
    Manufacturer="AssetFlow"
    Version="$(var.Version)"
    UpgradeCode="D0126F0D-53D8-45FA-AF81-92F82F4ECBF7"
    Language="1033"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of AssetFlow Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="AGENT_BASE_URL" Value="http://localhost:3000" />
    <Property Id="AGENT_BOOTSTRAP_TOKEN" Secure="yes" Hidden="yes" />

    <Feature Id="MainFeature" Title="AssetFlow Agent" Level="1">
      <ComponentRef Id="AgentScriptComponent" />
      <ComponentRef Id="ReadmeComponent" />
    </Feature>

    <InstallExecuteSequence>
      <Custom Action="RunAgentInstallCommand" After="InstallFinalize" Condition="NOT REMOVE" />
      <Custom Action="RunAgentUninstallCommand" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <CustomAction
      Id="RunAgentInstallCommand"
      Execute="immediate"
      Impersonate="yes"
      Return="check"
      Directory="INSTALLFOLDER"
      ExeCommand="[SystemFolder]WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[#AssetflowAgentPs1]&quot; -Mode Install -BootstrapToken &quot;[AGENT_BOOTSTRAP_TOKEN]&quot; -BaseUrl &quot;[AGENT_BASE_URL]&quot;" />

    <CustomAction
      Id="RunAgentUninstallCommand"
      Execute="deferred"
      Impersonate="no"
      Return="ignore"
      Directory="INSTALLFOLDER"
      ExeCommand="[SystemFolder]WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[#AssetflowAgentPs1]&quot; -Mode Uninstall" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AssetFlowAgent">
        <Component Id="AgentScriptComponent" Guid="A3892A82-8C06-4EE6-9E74-86A534725027">
          <File Id="AssetflowAgentPs1" Source="$(sys.SOURCEFILEDIR)..\..\public\downloads\assetflow-agent.ps1" KeyPath="yes" />
        </Component>
        <Component Id="ReadmeComponent" Guid="61A9CD0D-CB3E-44B1-8ED8-8E2FA0DFA503">
          <File Id="ReadmeAgentTxt" Source="$(sys.SOURCEFILEDIR)..\..\public\downloads\README-agent.txt" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
