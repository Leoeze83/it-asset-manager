# APP_URL: public base URL for the application.
APP_URL="https://assetflow.example.com"

# PORT: local server port.
PORT="3000"

# AGENT_BOOTSTRAP_TOKEN: one-time enrollment secret for secure agent registration.
# Generate a long random value and keep it only in server-side secrets management.
AGENT_BOOTSTRAP_TOKEN="replace-with-a-long-random-secret"

# AGENT_HEARTBEAT_INTERVAL_SECONDS: recommended heartbeat frequency for the secure inventory agent.
AGENT_HEARTBEAT_INTERVAL_SECONDS="60"
