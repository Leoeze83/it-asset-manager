# APP_URL: public base URL for the application.
APP_URL="https://assetflow.example.com"

# PORT: local server port.
PORT="3000"

# AGENT_BOOTSTRAP_TOKEN: one-time enrollment secret for secure agent registration.
# Generate a long random value and keep it only in server-side secrets management.
AGENT_BOOTSTRAP_TOKEN="replace-with-a-long-random-secret"

# AGENT_HEARTBEAT_INTERVAL_SECONDS: recommended heartbeat frequency for the secure inventory agent.
AGENT_HEARTBEAT_INTERVAL_SECONDS="14400"

# Firebase web config (do not commit real values in source files)
VITE_FIREBASE_API_KEY="replace-with-your-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID=""
